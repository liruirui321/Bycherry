{
  "name": "bycherry-homepage",
  "private": true,
  "version": "0.0.1",
  "description": "Science learning homepage with simulations, AI tools, and learning projects.",
  "homepage": "https://bycherry.me",
  "repository": {
    "type": "git",
    "url": "https://github.com/liruirui321/Bycherry.git"
  },
  "author": "Cherry",
  "type": "module",
  "scripts": {
    "build": "npm run generate:sitemap && npm run generate:index && npm run verify:generated && npm run verify:public && npm run verify:links && npm run verify:content && npm run verify:a11y && npm run verify:sitemap && npm run verify:wiring && vite build",
    "generate:index": "node scripts/generate-static-index.mjs",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "verify:a11y": "node scripts/verify-accessibility-refs.mjs",
    "verify:content": "node scripts/verify-content-integrity.mjs",
    "verify:generated": "node scripts/verify-generated-artifacts.mjs",
    "verify:links": "node scripts/verify-internal-links.mjs",
    "verify:public": "node scripts/verify-public-assets.mjs",
    "verify:domain": "node scripts/verify-domain-dns.mjs",
    "verify:sitemap": "node scripts/verify-sitemap.mjs",
    "verify:wiring": "node scripts/verify-project-wiring.mjs",
    "dev": "vite"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@vitejs/plugin-react": "4.7.0",
    "tailwindcss": "4.1.12",
    "vite": "6.3.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
}
